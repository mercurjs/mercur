{
  "name": "@mercurjs/core",
  "version": "2.1.0-canary.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/mercurjs/mercur",
    "directory": "packages/core"
  },
  "description": "Core plugin for MercurJS.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    ".": {
      "types": "./.medusa/server/src/with-mercur.d.ts",
      "default": "./.medusa/server/src/with-mercur.js"
    },
    "./_generated": {
      "types": "./.mercur/_generated/index.ts"
    },
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": {
      "types": "./.medusa/server/src/modules/*/index.d.ts",
      "default": "./.medusa/server/src/modules/*/index.js"
    },
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./with-mercur": {
      "types": "./.medusa/server/src/with-mercur.d.ts",
      "default": "./.medusa/server/src/with-mercur.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "marketplace",
    "multi-vendor",
    "medusajs",
    "ecommerce",
    "open-source-marketplace",
    "headless-commerce",
    "ai-ready",
    "marketplace-framework",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "bunx @mercurjs/cli codegen && rm -rf .medusa && tsc --declaration --outDir .medusa/server",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "tsc --declaration --outDir .medusa/server"
  },
  "devDependencies": {
    "cors": "^2.8.5",
    "@medusajs/core-flows": "^2.13.4",
    "@medusajs/cli": "^2.13.4",
    "@medusajs/framework": "^2.13.4",
    "@medusajs/icons": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@medusajs/test-utils": "^2.13.4",
    "@medusajs/ui": "4.1.1",
    "@mercurjs/types": "workspace:*",
    "@swc/core": "^1.7.28",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "yalc": "^1.0.0-pre.53",
    "@medusajs/types": "2.13.4",
    "zod": "3.25.76",
    "multer": "^2.0.2",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "@mercurjs/cli": "2.1.0-canary.7"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.13.4",
    "@medusajs/cli": "^2.13.4",
    "@medusajs/framework": "^2.13.4",
    "@medusajs/icons": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@medusajs/test-utils": "^2.13.4",
    "express": "^4.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {}
}
